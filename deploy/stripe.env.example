# Stripe billing — copy to /opt/cvbuilder/.env
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Create Products + recurring Prices in Stripe Dashboard, then paste Price IDs:
STRIPE_PRICE_PRO_MONTHLY=price_...
STRIPE_PRICE_PRO_YEARLY=price_...
STRIPE_PRICE_BUSINESS_MONTHLY=price_...
STRIPE_PRICE_BUSINESS_YEARLY=price_...

# Public URL for Stripe success/cancel redirects (no trailing slash)
CVBUILDER_PUBLIC_URL=http://65.108.236.135/cvbuilder

# Webhook endpoint:
#   http://65.108.236.135/cvbuilder/api/billing/webhook
# Events to enable in Stripe Dashboard:
#   - checkout.session.completed
#   - customer.subscription.updated
#   - customer.subscription.deleted
#   - invoice.paid
#   - invoice.payment_failed
