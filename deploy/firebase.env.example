# =============================================================================
# Firebase setup guide (TEMPLATE — do not put real secrets in git)
# =============================================================================
#
# 1) SERVICE ACCOUNT JSON (backend credential file)
#    - Firebase Console → Project Settings → Service accounts → Generate new key
#    - Save the downloaded file ON THE SERVER only (never commit to git):
#
#        sudo mkdir -p /opt/cvbuilder/secrets
#        sudo nano /opt/cvbuilder/secrets/firebase-service-account.json
#        # paste full JSON, save
#        sudo chown www-data:www-data /opt/cvbuilder/secrets/firebase-service-account.json
#        sudo chmod 600 /opt/cvbuilder/secrets/firebase-service-account.json
#
# 2) BACKEND env vars → add to /opt/cvbuilder/.env
#    (systemd already loads this via deploy/cvbuilder-backend.service)
#    Copy the FIREBASE_* and GOOGLE_APPLICATION_CREDENTIALS lines below into .env
#
# 3) FRONTEND env vars → add to /opt/cvbuilder/frontend/.env.production
#    (VITE_* vars are baked in at npm run build — not read by Python backend)
#    Then rebuild: sudo bash deploy/rebuild-frontend.sh
#
# Do NOT rename this file to firebase.env in the repo.
# On server you may use /opt/cvbuilder/.env only (recommended), or optionally
# create /opt/cvbuilder/firebase.env and add EnvironmentFile= to systemd.
# =============================================================================

# --- Frontend (copy to frontend/.env.production before build) ---
VITE_FIREBASE_API_KEY=AIzaSyBYvCTaEhd7C-wae_ACqY7Z4NaSR8QlYYc
VITE_FIREBASE_AUTH_DOMAIN=resumemaker-b51fc.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=resumemaker-b51fc
VITE_FIREBASE_STORAGE_BUCKET=resumemaker-b51fc.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=730737105607
VITE_FIREBASE_APP_ID=1:730737105607:web:3ae27fb087eb45fd29bce2

# --- Backend (copy to /opt/cvbuilder/.env) ---
FIREBASE_PROJECT_ID=resumemaker-b51fc
FIREBASE_STORAGE_BUCKET=resumemaker-b51fc.firebasestorage.app
GOOGLE_APPLICATION_CREDENTIALS=/opt/cvbuilder/secrets/firebase-service-account.json
# Only if you created a named Firestore DB (not "(default)"):
# FIRESTORE_DATABASE_ID=(default)
# Important: production must keep local auth fallback OFF, otherwise all users
# can see the old shared local CV list.
CVBUILDER_ALLOW_LOCAL_AUTH=0
# Alternative: paste minified JSON on one line instead of a file path:
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

CVBUILDER_PUBLIC_URL=http://65.108.236.135/cvbuilder
