# OPTIONAL — only if you want to STOP serving /cvbuilder/ on the main IP
# and redirect users to the subdomain. Most setups should NOT use this.
#
# Default: keep BOTH
#   http://65.108.236.135/cvbuilder/  → dist/ (unchanged)
#   http://cv.buzzwaretech.com/         → dist-subdomain/

    location = /cvbuilder {
        return 301 http://cv.buzzwaretech.com/;
    }

    location /cvbuilder/ {
        rewrite ^/cvbuilder/?(.*)$ http://cv.buzzwaretech.com/$1 permanent;
    }
