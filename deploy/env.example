# Copy to /opt/cvbuilder/.env and adjust values
# systemd service loads this via EnvironmentFile=

CVBUILDER_HOST=127.0.0.1
CVBUILDER_PORT=8001

# Comma-separated origins (your server IP or domain)
CVBUILDER_CORS_ORIGINS=http://65.108.236.135

OLLAMA_URL=http://127.0.0.1:11434/api/generate
OLLAMA_MODEL=qwen2.5:7b

CVBUILDER_DATA_DIR=/opt/cvbuilder/data
